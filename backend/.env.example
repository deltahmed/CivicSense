# Django
SECRET_KEY=your-secret-key-generate-a-long-random-string
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0,backend

# PostgreSQL (Docker)
DB_NAME=civicsense
DB_USER=civicsense
DB_PASSWORD=civicsense_dev_password
DB_HOST=db
DB_PORT=5432

# CORS (Frontend origin)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://frontend:5173
CORS_ALLOW_CREDENTIALS=True

# Admin user (created at startup)
ADMIN_EMAIL=admin@civicsense.local
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin1234

# Seed test data (set to True to populate database)
SEED_TEST_DATA=True

# Email (Optional)
# EMAIL_HOST=sandbox.smtp.mailtrap.io
# EMAIL_PORT=2525
# EMAIL_HOST_USER=your_mailtrap_user
# EMAIL_HOST_PASSWORD=your_mailtrap_password
# EMAIL_USE_TLS=True
# DEFAULT_FROM_EMAIL=noreply@civicsense.local

# JWT (Optional - auto-generated if not set)
# JWT_SIGNING_KEY=your-jwt-signing-key
